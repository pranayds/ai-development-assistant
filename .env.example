# AI Development Assistant Configuration Template
# Copy this file to .env and fill in your actual values

# LLM Configuration
# For OpenAI-compatible APIs (e.g., OpenAI, Azure OpenAI, local models)
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_API_MODEL=gpt-4

# Alternative: Use local models via Ollama or other local inference servers
# OPENAI_API_BASE_URL=http://localhost:11434/v1
# OPENAI_API_MODEL=llama2

# Embedding Configuration
# Options: 'local' (uses sentence-transformers, free & offline) or 'openai' (uses API)
EMBEDDING_MODE=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: If using OpenAI embeddings instead of local
# EMBEDDING_MODE=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
